      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has id', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.id).to.not.be.null;",
                  "    pm.collectionVariables.set('taskId', json.id);",
                  "});",
                  "",
                  "pm.test('Status defaults to TODO', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('TODO');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Task\",\n  \"description\": \"This is a test task\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tasks"
              ]
            }
          },
          "response": []
        },
